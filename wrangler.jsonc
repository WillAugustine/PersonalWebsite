{
	"$schema": "./node_modules/wrangler/config-schema.json",
	"name": "personalwebsite",
	"main": "src/worker.ts",
	"compatibility_date": "2026-05-15",
	"assets": {
		"directory": "./dist/",
		"not_found_handling": "single-page-application"
	},
	"routes": [
		{
			"pattern": "*.william-augustine.com/*",
			"zone_name": "william-augustine.com"
		}
	],
	"kv_namespaces": [
		{
			"binding": "CHAT_RATE_LIMIT",
			"id": "6a3a144a6add4012b7b3b148ef49c11b"
		}
	],
	"vars": {
		"BUG_REPORT_FROM": "bug-reports@william-augustine.com",
		"BUG_REPORT_TO": "willaugustine64@outlook.com",
		"OPENAI_MODEL": "gpt-5.4-nano",
		"CHAT_MAX_MESSAGES": "6",
		"CHAT_WINDOW_SECONDS": "900"
	}
}
