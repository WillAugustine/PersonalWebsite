{
	"$schema": "./node_modules/wrangler/config-schema.json",
	"name": "personalwebsite",
	"main": "src/worker.ts",
	"compatibility_date": "2026-05-15",
	"assets": {
		"directory": "./dist/",
		"not_found_handling": "single-page-application"
	},
	"routes": [
		{
			"pattern": "*.william-augustine.com/*",
			"zone_name": "william-augustine.com"
		}
	],
	"vars": {
		"BUG_REPORT_FROM": "bug-reports@william-augustine.com",
		"BUG_REPORT_TO": "willaugustine64@outlook.com"
	}
}